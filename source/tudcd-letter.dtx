% Um am meisten Konfigurierbarkeit zu bieten, werden zwei weitere Variablen für
% die obere Infobox sowie für die untere Infobox bereitgestellt.
% Damit können Nutzer den kompletten Inhalt, oder die Formatierung überschreiben.
%    \begin{macrocode}
\newkomavar{toplocation} % Obere Infobox
\newkomavar{bottomlocation} % Untere Infobox
\newkomafont{toplocation}{
\fontsize{7\tudpt}{9\tudpt}\selectfont

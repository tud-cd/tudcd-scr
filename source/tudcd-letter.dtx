% Hier werden die entsprechenden zusätzlichen Variablen definiert, welche die einzelnen
% zusätzlichen Felder definieren. Dabei ist insbesondere die Position einer Person oder die
% Struktureinheit eine zusätzliche Information dar.
%    \begin{macrocode}
\newkomavar{fromentity} % Struktureinheit
\newkomavar{fromposition} % Position in der Fakultät
%    \end{macrocode}
% Weiterhin werden die textuellen Bezeichner auf sinnvolle Standardwerte gesetzt.
%    \begin{macrocode}
\setkomavar*{fromphone}{T~}
\setkomavar*{fromfax}{F~}
\setkomavar*{fromaddress}{Besuchsaddresse}
\setkomavar*{yourref}{Aktenzeichen}
%    \end{macrocode}
% Innerhalb der Vorlage wurden mehrere \emph{Blöcke} an Informationen
% identifiziert, welche zusammen gesetzt werden. Zwischen diesen Blöcken sollen jeweils 10 pt platz sein.
%
% \begin{table}[H]
%   \centering
%   \begin{tabular}{rll}
%     Struktureinheit  & \texttt{fromentity} & Struktureinheit \\
%                      & \texttt{fromlogo} & Zweitlogo der Struktureinheit \\ \hline
%     Personalangaben  & \texttt{fromname} & Name der Person \\
%                      & \texttt{fromposition} & Position der Person \\ \hline
%     Kontaktdaten     & \texttt{fromphone} & Telefonnummer \\
%                      & \texttt{fromfax} & Faxnummer \\
%                      & \texttt{fromemail} & Email-Addressen \\
%                      & \texttt{fromurl} & Website \\ \hline
%     Besuchsaddresse  & \texttt{fromaddress} & Besuchsaddresse \\ \hline
%     Aktenzeichen     & \texttt{yourref} & Aktenzeichen \\
%                      & \texttt{date} & Datum \\
%   \end{tabular}
% \end{table}
%
% Um die einzelnen Blöcke korrekt zu setzen wird \dmacro{\par}s Funktionalität bei leeren Zeilen
% sich nicht verdoppeln ausgenutzt.
%
%    \begin{macrocode}
\setkomavar{toplocation}{%
\Ifkomavarempty{fromentity}{}{\usekomavar{fromentity} \par }
\group_begin:
\Ifkomavarempty{fromlogo}{}{ \leavevmode \usekomavar{fromlogo} } \par
\group_end:
%
\Ifkomavarempty{fromname}{}{\usekomavar{fromname}}
\Ifkomavarempty{fromposition}{}{\\ \usekomavar{fromposition}} \par
%
\Ifkomavarempty{fromphone}{}{\usekomavar*{fromphone}\usekomavar{fromphone}}
\Ifkomavarempty{fromfax}{}{\\ \usekomavar*{fromfax}\usekomavar{fromfax}}
\Ifkomavarempty{fromemail}{}{\\ \usekomavar{fromemail}}
\Ifkomavarempty{fromurl}{}{\\ \usekomavar{fromurl}} \par
%
\Ifkomavarempty{fromaddress}{}{\usekomavar*{fromaddress} \\ \usekomavar{fromaddress}} \par
%
\Ifkomavarempty{yourref}{}{\usekomavar*{yourref} \\ \usekomavar{yourref} \\}
\Ifkomavarempty{date}{}{\usekomavar{date}}
}
%    \end{macrocode}
%
% Um Zweitlogos eines Instituts mit der richtigen Höhe zu versehen, wird ein Interner und Externer Befehl bereitgestellt,
% welcher das Logo auf $2/3$ des TUD Logos skaliert.
% Dabei wird zuerst das Logo als Box gesetzt, und diese Box wird ausgemessen.
% Anschließend werden die Verhältnisse der Breiten und Höhen zu den zulässigen Breiten und Höhen
% berechnet und die Box wird um das kleinere der beiden Verhältnisse skaliert.
%
%    \begin{macrocode}
\box_new:N \l_@@_second_logo_box
\cs_new:Nn \@@_second_logo_typeset:n {
  \hbox_set:Nn \l_@@_second_logo_box { #1 }
  % Verhältnis zwischen den Höhen
  \tl_set:Ne \l_tmpa_tl { \dim_ratio:nn { 11.3333 mm } { \dim_max:nn{ 11.3333 mm }{ \box_ht:N \l_@@_second_logo_box } } }
  % Verhältnis zwischen den Breiten.
  \tl_set:Ne \l_tmpb_tl { \dim_ratio:nn { 43 mm } { \dim_max:nn{ 43 mm }{ \box_wd:N \l_@@_second_logo_box } } }
  % Nutze l3box!
  \box_scale:Nnn \l_@@_second_logo_box { min( \l_tmpa_tl ,\l_tmpb_tl) } { min( \l_tmpa_tl, \l_tmpb_tl) }
  % Jetzt hat die Box die Richtige Größe
  \box_use_drop:N\l_@@_second_logo_box
}
\NewDocumentCommand\TypesetSecondLogo{m}{
  \@@_second_logo_typeset:n{#1}
}
%    \end{macrocode}
